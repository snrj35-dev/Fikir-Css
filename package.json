{
  "name": "fikir-css",
  "version": "1.0.0",
  "description": "Contract-driven CSS design system. Zero-runtime, token-first, 99 surfaces in ~18KB gzip.",
  "keywords": [
    "css",
    "design-system",
    "ui",
    "components",
    "tokens",
    "zero-runtime",
    "framework"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snrj35-dev/Fikir-Css.git"
  },
  "homepage": "https://snrj35-dev.github.io/Fikir-Css/",
  "bugs": {
    "url": "https://github.com/snrj35-dev/Fikir-Css/issues"
  },
  "type": "module",
  "style": "./dist/fikir.css",
  "exports": {
    ".": {
      "default": "./dist/fikir.css"
    },
    "./css": "./dist/fikir.css",
    "./contracts/selectors": "./dist/contracts/selectors.json",
    "./contracts/alias-migration": "./dist/contracts/alias-migration.json",
    "./contracts/size-report": "./dist/contracts/size-report.json",
    "./contracts/contract-drift-report": "./dist/contracts/contract-drift-report.json",
    "./contracts/bundle-layers-report": "./dist/contracts/bundle-layers-report.json",
    "./contracts/component-css-map": "./dist/contracts/component-css-map.json",
    "./contracts/anatomy": "./dist/contracts/anatomy.json",
    "./contracts/capabilities": "./dist/contracts/capabilities.json",
    "./contracts/variants": "./dist/contracts/variants.json",
    "./contracts/primitives": "./dist/contracts/primitives.json",
    "./tooling": {
      "types": "./dist/tooling/resolve-classes.d.ts",
      "default": "./dist/tooling/resolve-classes.mjs"
    },
    "./resolvers": {
      "types": "./dist/tooling/resolve-classes.d.ts",
      "default": "./dist/tooling/resolve-classes.mjs"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "default": "./dist/helpers/index.mjs"
    },
    "./tokens": "./dist/tokens.json",
    "./themes/dark": "./dist/themes/dark.css",
    "./themes/light": "./dist/themes/light.css",
    "./themes/high-contrast": "./dist/themes/high-contrast.css",
    "./themes/compact": "./dist/themes/compact.css",
    "./themes/comfortable": "./dist/themes/comfortable.css",
    "./themes/reduced-motion": "./dist/themes/reduced-motion.css",
    "./themes/shape": "./dist/themes/shape.css",
    "./slices/forms": "./packages/slices/forms.css",
    "./slices/overlays": "./packages/slices/overlays.css",
    "./slices/navigation": "./packages/slices/navigation.css",
    "./slices/data-display": "./packages/slices/data-display.css"
  },
  "files": [
    "dist/**",
    "packages/slices/**",
    "packages/components/**",
    "packages/tokens/**",
    "README.md",
    "LICENSE",
    "docs/release/release-note-template.md",
    "docs/migration/migration-note-template.md"
  ],
  "types": "./dist/tooling/resolve-classes.d.ts",
  "scripts": {
    "build": "node scripts/build-css.mjs && node scripts/report-contract-drift.mjs && node scripts/report-bundle-layers.mjs && node scripts/report-component-css-map.mjs && node scripts/generate-manifests.mjs",
    "build:manifests": "node scripts/generate-manifests.mjs",
    "build:css": "node scripts/build-css.mjs",
    "docs:validate": "node --test tests/source/docs-link-audit.test.mjs",
    "docs:quality": "node scripts/check-docs-quality.mjs",
    "docs:quality:strict": "node scripts/check-docs-quality.mjs --strict",
    "docs:examples": "node scripts/validate-docs-examples.mjs",
    "docs:examples:fix": "node scripts/validate-docs-examples.mjs --fix",
    "capture:playground": "node scripts/capture-playground-screenshots.mjs",
    "screenshot:diff": "node scripts/diff-playground-screenshots.mjs",
    "validate:size": "node scripts/validate-size-thresholds.mjs",
    "validate:prefixed": "node scripts/validate-prefixed-smoke.mjs",
    "report:size": "node scripts/report-size-diff.mjs",
    "report:contract-drift": "node scripts/report-contract-drift.mjs",
    "report:bundle-layers": "node scripts/report-bundle-layers.mjs",
    "report:contrast": "node scripts/report-contrast-regression.mjs",
    "report:component-map": "node scripts/report-component-css-map.mjs",
    "report:dead-surfaces": "node scripts/report-dead-surfaces.mjs",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "detect:anatomy-drift": "node scripts/detect-css-anatomy-drift.mjs",
    "detect:stale-anatomy": "node scripts/detect-stale-anatomy.mjs",
    "validate:recipe-strict": "node scripts/validate-recipe-strict.mjs",
    "detect:flaky-tests": "node scripts/detect-flaky-tests.mjs",
    "validate:playground-baseline": "node scripts/validate-playground-baseline.mjs",
    "validate:publish": "node scripts/validate-publishable-outputs.mjs",
    "validate:version": "node scripts/validate-version-tag-consistency.mjs",
    "package:smoke": "node scripts/package-smoke.mjs",
    "github:bootstrap": "node scripts/bootstrap-github-roadmap.mjs",
    "test:source": "node --test tests/source/*.test.mjs",
    "test:build": "node --test tests/build/*.test.mjs",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:ui": "playwright test --ui",
    "validate:examples": "node scripts/validate-example-structure.mjs",
    "test:ci": "npm run build && npm run test:source && npm run docs:validate && npm run docs:examples && npm run docs:quality:strict && npm run validate:size && npm run validate:prefixed && npm run validate:playground-baseline && npm run validate:publish && npm run validate:version && npm run package:smoke && npm run test:build && npm run validate:examples && npm run validate:manifests && npm run validate:recipe-strict && npm run detect:anatomy-drift && npm run detect:stale-anatomy",
    "test": "npm run test:ci"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
